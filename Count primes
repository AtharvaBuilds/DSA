class Solution {
    public int countPrimes(int n) {
        if(n<=2){
            return 0;
        }
        int arr[]=new int[n];
        int count=0;
        for(int i=0;i<arr.length;i++){
            arr[i]=0;
        }
        arr[0]=arr[1]=1;
        for(int i=2;i<arr.length;i++){
             if(arr[i]==0){
                count++;
            for(int j=i*2;j<arr.length;j=j+i){
               arr[j]=1;
            }
                }
        }
        return count;
    }
}
